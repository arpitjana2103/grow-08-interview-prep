{
    "$schema": "./node_modules/oxlint/configuration_schema.json",
    "plugins": ["unicorn", "typescript", "oxc", "eslint"],
    "options": {
        "typeAware": true,
        "typeCheck": true
    },
    "rules": {
        "@typescript-eslint/explicit-function-return-type": "warn",
        "@typescript-eslint/no-unused-vars": "off"
    }
}
